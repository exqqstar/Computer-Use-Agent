# ═══════════════════════════════════════════════════════════════
#  AgentBeats — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your API keys.
#
#  Quick start (MiniMax China):
#    AGENT_API_BASE=https://api.minimaxi.com/v1
#    GREEN_API_BASE=https://api.minimaxi.com/v1
#
#  Quick start (MiniMax International):
#    AGENT_API_BASE=https://api.minimax.io/v1
#    GREEN_API_BASE=https://api.minimax.io/v1
#
#  Quick start (OpenAI):
#    AGENT_API_BASE=https://api.openai.com/v1
#    GREEN_API_BASE=https://api.openai.com/v1
#    (and update model names in scenario.toml to e.g. "openai/gpt-4o")
#
# ═══════════════════════════════════════════════════════════════

# ── Purple Agent (the agent being tested) ─────────────────────
AGENT_API_BASE=https://api.minimaxi.com/v1
AGENT_API_KEY=

# ── Green Agent (user simulator + policy evaluator) ───────────
GREEN_API_BASE=https://api.minimaxi.com/v1
GREEN_API_KEY=

# ── Provider-native keys (only needed if using native litellm routing) ──
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# MINIMAX_API_KEY=

# ── Logging ───────────────────────────────────────────────────
LOGURU_LEVEL=DEBUG
LOG_FORMAT=text
